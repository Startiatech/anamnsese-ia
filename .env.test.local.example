# Credenciais para testes de integração (Supabase branch ou projeto de teste isolado)
# Copie para .env.test.local e preencha com os valores do seu branch de teste.
# .env.test.local já está no .gitignore — nunca commite segredos.
#
# Sem essas variáveis, npm run test:integration usa as credenciais do .env.local (mesmo projeto de dev).
# Para isolamento total, crie um Supabase branch: mcp__supabase__create_branch

TEST_SUPABASE_URL=https://<seu-projeto-de-teste>.supabase.co
TEST_SUPABASE_SERVICE_KEY=<service-role-key-do-projeto-de-teste>
